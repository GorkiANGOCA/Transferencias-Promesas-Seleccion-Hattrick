{
  "manifest_version": 3,
  "name": "Hattrick - Lista de Transferencias (NT)",
  "version": "1.0",
  "description": "Agrupa a los jugadores en lista de transferencia en una sección consolidada y colapsable.",
  "icons": {
            "16": "icon16.png",
            "32": "icon32.png",
            "48": "icon48.png",
            "64": "icon64.png",
            "96": "icon96.png",
            "128": "icon128.png"
    },

  "content_scripts": [
    {
      "matches": [
        "*://stage.hattrick.org/*",
        "*://*.hattrick.org/*"
      ],
      "js": ["content-script.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ]
}
